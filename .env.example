
DATABASE_URL=postgresql://user:pass@host:port/dbname

SECRET_KEY=your-secure-random-key-here 

STORAGE_BACKEND=s3
S3_BUCKET_NAME=your-bucket-name
S3_REGION=us-east-1
S3_ENDPOINT_URL=  
S3_ACCESS_KEY_ID=your-access-key
S3_SECRET_ACCESS_KEY=your-secret-key
S3_PREFIX=uploads

APP_ENV=production
REPORT_BASE_URL=https://auto-analytics-ai-web.onrender.com
CORS_ORIGINS=https://auto-analytics-ai-web.onrender.com,https://auto-analytics-ai-web.onrender.com/*

CELERY_BROKER_URL=redis://...  
CELERY_RESULT_BACKEND=redis://...

UPLOAD_SESSION_EXPIRY_MINUTES=1440
